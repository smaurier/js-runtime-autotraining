{
  "name": "js-runtime-course",
  "version": "1.0.0",
  "description": "Formation avancée sur le runtime JavaScript (V8, event loop, mémoire, JIT)",
  "type": "module",
  "scripts": {
    "docs:copy-assets": "npx tsx scripts/copy-assets.ts",
    "docs:dev": "npm run docs:copy-assets && vitepress dev",
    "docs:build": "npm run docs:copy-assets && vitepress build",
    "docs:preview": "vitepress preview",
    "lab:01": "npx tsx labs/lab-01-call-stack-observation/exercise.ts",
    "lab:02": "npx tsx labs/lab-02-closure-memory/exercise.ts",
    "lab:03": "npx tsx labs/lab-03-event-loop-order/exercise.ts",
    "lab:04": "npx tsx labs/lab-04-microtask-macrotask/exercise.ts",
    "lab:05": "npx tsx labs/lab-05-promise-implementation/exercise.ts",
    "lab:05:step1": "npx tsx labs/lab-05-promise-implementation/exercise-step1.ts",
    "lab:05:step2": "npx tsx labs/lab-05-promise-implementation/exercise-step2.ts",
    "lab:05:step3": "npx tsx labs/lab-05-promise-implementation/exercise-step3.ts",
    "lab:06": "npx tsx labs/lab-06-async-patterns-comparison/exercise.ts",
    "lab:07": "node --import tsx/esm --expose-gc labs/lab-07-gc-observation/exercise.ts",
    "lab:08": "node --import tsx/esm --max-old-space-size=100 labs/lab-08-memory-leak-detection/exercise.ts",
    "lab:09": "node --import tsx/esm --print-bytecode --print-bytecode-filter=hotFunction labs/lab-09-v8-optimization/exercise.ts",
    "lab:10": "node --import tsx/esm --trace-opt --trace-deopt labs/lab-10-jit-deoptimization/exercise.ts",
    "lab:11": "node --import tsx/esm --allow-natives-syntax labs/lab-11-hidden-classes/exercise.ts",
    "lab:12": "node --import tsx/esm --prof labs/lab-12-performance-profiling/exercise.ts",
    "lab:13": "npx tsx labs/lab-13-scheduler-implementation/exercise.ts",
    "lab:14": "npx tsx labs/lab-14-mini-event-loop/exercise.ts",
    "lab:15": "node --import tsx/esm --expose-gc --trace-gc labs/lab-15-debugging-session/exercise.ts",
    "solution:01": "npx tsx labs/lab-01-call-stack-observation/solution.ts",
    "solution:02": "npx tsx labs/lab-02-closure-memory/solution.ts",
    "solution:03": "npx tsx labs/lab-03-event-loop-order/solution.ts",
    "solution:04": "npx tsx labs/lab-04-microtask-macrotask/solution.ts",
    "solution:05": "npx tsx labs/lab-05-promise-implementation/solution.ts",
    "solution:06": "npx tsx labs/lab-06-async-patterns-comparison/solution.ts",
    "solution:07": "node --import tsx/esm --expose-gc labs/lab-07-gc-observation/solution.ts",
    "solution:08": "node --import tsx/esm --max-old-space-size=100 labs/lab-08-memory-leak-detection/solution.ts",
    "solution:09": "node --import tsx/esm --print-bytecode --print-bytecode-filter=hotFunction labs/lab-09-v8-optimization/solution.ts",
    "solution:10": "node --import tsx/esm --trace-opt --trace-deopt labs/lab-10-jit-deoptimization/solution.ts",
    "solution:11": "node --import tsx/esm --allow-natives-syntax labs/lab-11-hidden-classes/solution.ts",
    "solution:12": "node --import tsx/esm --prof labs/lab-12-performance-profiling/solution.ts",
    "solution:13": "npx tsx labs/lab-13-scheduler-implementation/solution.ts",
    "solution:14": "npx tsx labs/lab-14-mini-event-loop/solution.ts",
    "solution:15": "node --import tsx/esm --expose-gc --trace-gc labs/lab-15-debugging-session/solution.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitepress": "^1.6.0"
  }
}
